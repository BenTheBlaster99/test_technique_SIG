{
  "name": "test-technique-vuejs",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm --prefix app run dev",
    "api": "json-server --watch db.json --host 0.0.0.0 --port ${PORT:-3000}",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "build": "npm --prefix app run build",
    "check": "npm --prefix app run check"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "json-server": "^0.17.4"
  }
}
